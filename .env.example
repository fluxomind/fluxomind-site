# Webhook que recebe os leads do form do beta (POST JSON).
# Configurar ANTES de publicar — ver docs/leads-analytics.md.
LEAD_WEBHOOK_URL=

# Webhook que recebe os eventos de analytics do site (POST JSON). Opcional.
EVENTS_WEBHOOK_URL=

# Token da página interna /admin/leads (obrigatório em produção; sem ele, 404).
ADMIN_TOKEN=

# Caminho do arquivo NDJSON de leads (padrão: <projeto>/data/leads.ndjson).
LEADS_FILE=
